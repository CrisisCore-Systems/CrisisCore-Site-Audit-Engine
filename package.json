  "license": "MIT",
  "dependencies": {
    "@axe-core/playwright": "^4.9.1",
    "cheerio": "^1.0.0",
    "chrome-launcher": "^1.1.2",
    "commander": "^12.1.0",
    "handlebars": "^4.7.9",
    "lighthouse": "^12.2.0",
    "markdown-it": "^14.1.0",
    "p-limit": "^4.0.0",
    "playwright": "^1.55.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
