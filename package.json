{
  "name": "crisiscore-site-audit-engine",
  "version": "0.1.0",
  "description": "CrisisCore Site Audit Engine — trust teardown system that produces proof-backed, client-ready audit packets",
  "type": "module",
  "bin": {
    "crisiscore-audit": "./dist/cli.js"
  },
  "scripts": {
